# ============================================================
# 倾听助手 生产等价环境配置模板
# 复制为 .env.prod 后填入真实强秘密
# 启动: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d --wait
# ============================================================

# --- 必填：强秘密（至少 32 字符，不含 change-me/development/default 等弱标记） ---
JWT_SECRET=<生成: openssl rand -hex 32>
SERVICE_API_TOKEN=<生成: openssl rand -hex 32>
POSTGRES_PASSWORD=<生成: openssl rand -hex 24>

# --- 生产标识 ---
APP_ENV=production

# --- 域名与 CORS（必须为显式白名单，不允许 *） ---
SITE_ADDRESS=your-domain.com
CORS_ORIGINS=https://your-domain.com
RASA_CORS_ORIGIN=https://your-domain.com

# --- 数据库 ---
POSTGRES_DB=tingting
POSTGRES_USER=tingting

# --- 对象存储（生产必须使用强凭据） ---
MINIO_ROOT_USER=<生成: 强用户名>
MINIO_ROOT_PASSWORD=<生成: openssl rand -hex 24>
OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=<同 MINIO_ROOT_USER>
OBJECT_STORAGE_SECRET_KEY=<同 MINIO_ROOT_PASSWORD>
OBJECT_STORAGE_BUCKET=tingting-attachments
OBJECT_STORAGE_SECURE=true

# --- 恶意文件扫描（生产强制开启） ---
MALWARE_SCAN_MODE=clamd
MALWARE_SCAN_URL=clamav:3310
MALWARE_SCAN_REQUIRE_CLEAN=true
MALWARE_SCAN_TIMEOUT_SECONDS=30

# --- 限流 ---
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- 日志 ---
LOG_LEVEL=INFO

# --- 时区 ---
DEFAULT_TIMEZONE=Asia/Shanghai

# --- Worker ---
WORKER_ENABLED=true
WORKER_SCAN_INTERVAL_SECONDS=60
WORKER_DUE_SOON_HOURS=4

# --- AI 大模型（留空 AI_API_KEY 则降级为规则引擎） ---
AI_PROVIDER=deepseek
AI_API_KEY=<填入 DeepSeek API Key>
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=1024

# --- 可选：OIDC ---
OIDC_ENABLED=false
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://your-domain.com/auth/oidc/callback
