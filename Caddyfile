{$SITE_ADDRESS:localhost} {
	# Defense in depth: never reverse-proxy internal operational metrics.
	handle /metrics* {
		respond 404
	}
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /rasa/* {
		uri strip_prefix /rasa
		reverse_proxy rasa:5005
	}
	handle {
		reverse_proxy frontend:80
	}
	encode gzip
}
