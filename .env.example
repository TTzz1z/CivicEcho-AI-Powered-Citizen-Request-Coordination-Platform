# Copy to .env, then fill every required secret. Empty values intentionally make Compose fail fast.
APP_ENV=development
POSTGRES_DB=tingting
POSTGRES_USER=tingting
POSTGRES_PASSWORD=
JWT_SECRET=
SERVICE_API_TOKEN=
SEED_PASSWORD=
SEED_PROFILE=demo
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

FRONTEND_PORT=8080
BACKEND_PORT=8001
RASA_PORT=5005
ACTION_SERVER_PORT=5055
DUCKLING_PORT=8000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
FRONTEND_BACKEND_UPSTREAM=http://backend:8000
FRONTEND_RASA_UPSTREAM=http://rasa:5005
ACTION_SERVER_URL=http://action_server:5055/webhook
DUCKLING_URL=http://duckling:8000
TICKET_BACKEND_MODE=http
TICKET_SERVICE_URL=http://backend:8000
TICKET_SERVICE_TIMEOUT_SECONDS=5

CORS_ORIGINS=http://localhost:8080,http://localhost:5173
RASA_CORS_ORIGIN=http://localhost:8080
JWT_ACCESS_TOKEN_MINUTES=30
MAX_REQUEST_BODY_BYTES=1048576
DATABASE_CONNECT_TIMEOUT_SECONDS=5
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Shanghai
ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_IMAGE_MAX_BYTES=10485760
OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=tingting-attachments
OBJECT_STORAGE_SECURE=false
MALWARE_SCAN_MODE=disabled
MALWARE_SCAN_URL=
MALWARE_SCAN_TOKEN=
MALWARE_SCAN_TIMEOUT_SECONDS=30
MALWARE_SCAN_REQUIRE_CLEAN=false

# Phase 6: every external connector is disabled until its URL and secret are injected.
# AI_PROVIDER: rules (default, offline rule engine) or deepseek (OpenAI-compatible LLM)
AI_PROVIDER=rules
AI_MODEL_NAME=phase6-rules-v1
# Phase 4 real LLM (leave AI_API_KEY empty to keep rule fallback):
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=1024

# Embedding / RAG (SiliconFlow OpenAI-compatible). Leave EMBEDDING_API_KEY empty
# to use deterministic hash fallback (demo only; recorded as embedding_fallback).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_SECONDS=30

INTEGRATION_TIMEOUT_SECONDS=10
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/auth/oidc/callback
OIDC_SCOPES=openid profile email
DIRECTORY_API_URL=
DIRECTORY_API_TOKEN=
WORK_ORDER_PLATFORM=disabled
WORK_ORDER_API_URL=
WORK_ORDER_API_TOKEN=
SMS_API_URL=
SMS_API_TOKEN=
MAP_API_URL=
MAP_API_TOKEN=
DIVISION_API_URL=
DIVISION_API_TOKEN=
CENTRAL_LOG_ENDPOINT=
CENTRAL_LOG_TOKEN=
MONITORING_ENDPOINT=
MONITORING_TOKEN=

# Keep local mode unless credentials are injected from a secret store.
SERVICENOW_LOCAL_MODE=true
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SERVICENOW_TIMEOUT_SECONDS=10
HANDOFF_HOST_KEY=configured_handoff
HANDOFF_HOST_TITLE=人工服务
HANDOFF_HOST_URL=
